APP_NAME=HotelHarmony
APP_ENV=development
LOG_LEVEL=debug
FRONTEND_URL=http://localhost:8080

HTTP_HOST=0.0.0.0
HTTP_PORT=8787

DATABASE_URL=postgres://hotel:harmony@localhost:5432/hotel_harmony?sslmode=disable
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=1h
DB_CONN_MAX_IDLE_TIME=15m

REDIS_URL=
REDIS_DB=0

JWT_ACCESS_SECRET=replace-with-long-random-access-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
BCRYPT_COST=12

STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
